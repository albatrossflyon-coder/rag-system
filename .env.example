# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# Pinecone Vector DB (optional for local corpus runs)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=rag-production
PINECONE_ENVIRONMENT=us-west-2

# Cohere Reranking (optional; local heuristic reranking is used when omitted)
COHERE_API_KEY=your-cohere-api-key

# Railway/Render deployment
DEPLOYMENT_ENV=local

# Vercel frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Evaluation settings
RAGAS_BATCH_SIZE=10
EVAL_THRESHOLD_FAITHFULNESS=0.75
EVAL_THRESHOLD_RELEVANCE=0.80
